# ═══════════════════════════════════════════════════════════════
# MDB BFF — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs réelles
# NE JAMAIS committer le fichier .env dans Git
# ═══════════════════════════════════════════════════════════════

# ── Flask ────────────────────────────────────────────────────
FLASK_APP=run.py
FLASK_ENV=development
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGEZ-MOI-valeur-aleatoire-longue-en-production

# ── Base de données PostgreSQL ───────────────────────────────
# Format : postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://mdb_user:mot_de_passe@localhost:5432/mdb_bff

# ── Chemin réseau BFF (UNC Windows) ──────────────────────────
# Dossier racine de stockage des affaires sur le NAS
NETWORK_BASE_PATH=\\BFF-FICHIERS\Affaires
# En développement local, utiliser un chemin local :
# NETWORK_BASE_PATH=C:\Dev\MDB_BFF\pdf_output

# ── Email (alertes jalons + certifications) ──────────────────
SMTP_SERVER=smtp.bff.local
SMTP_PORT=587
SMTP_USER=mdb-noreply@bff.fr
SMTP_PASSWORD=
SMTP_USE_TLS=true
ALERT_EMAIL=qualite@bff.fr

# ── Uploads ──────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=20
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,tiff

# ── Session ──────────────────────────────────────────────────
# Durée de session en minutes (8h pour journée atelier)
SESSION_TIMEOUT_MINUTES=480

# ── Logo BFF ─────────────────────────────────────────────────
LOGO_PATH=static/img/logo_bff.svg

# ── Celery / Redis (génération PDF asynchrone) ───────────────
REDIS_URL=redis://localhost:6379/0

# ── Authentification Windows / Active Directory (optionnel) ──
# Activer l'auth LDAP (connexion avec identifiant Windows AD)
WINDOWS_AUTH_ENABLED=false
# Adresse du serveur LDAP/AD BFF (ex: ldap://dc.bff.local)
LDAP_SERVER=ldap://dc.bff.local
# Base DN de recherche (ex: dc=bff,dc=local)
LDAP_BASE_DN=dc=bff,dc=local
# DN de l'utilisateur de service pour les recherches LDAP
LDAP_BIND_DN=cn=mdb-service,ou=services,dc=bff,dc=local
LDAP_BIND_PASSWORD=

# ── WeasyPrint (Windows uniquement) ──────────────────────────
# Requis si GTK est installé via MSYS2.
# Installation : pacman -S mingw-w64-x86_64-pango (dans MSYS2 MinGW64)
# Laisser vide ou commenter sur Linux/NAS Synology.
WEASYPRINT_DLL_DIRECTORIES=C:\msys64\mingw64\bin
